{
  "name": "axon-lang",
  "version": "0.2.0",
  "description": "Axon - A programming language designed for AI Agents",
  "main": "dist/main.js",
  "bin": {
    "axon": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "ts-node src/main.ts",
    "run:demo": "ts-node src/main.ts run demo/counter.axon",
    "run:all": "ts-node src/main.ts run demo/full_demo.axon",
    "check": "ts-node src/main.ts check",
    "watch": "ts-node src/main.ts run demo/hot_reload_demo.axon --watch"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
