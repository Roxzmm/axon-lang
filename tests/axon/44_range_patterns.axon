module Test

// Test 44: Range patterns in match
// n..=m  — inclusive range (n <= x <= m)
// n..m   — exclusive range (n <= x < m)
// Works with Int and Float

fn classify_int(x: Int) -> String {
    match x {
        0..=2   => "low",
        3..=7   => "mid",
        8..=12  => "high",
        _       => "very high",
    }
}

fn classify_float(f: Float) -> String {
    match f {
        0.9..=1.0 => "A",
        0.8..=0.9 => "B",
        0.7..=0.8 => "C",
        0.6..=0.7 => "D",
        _         => "F",
    }
}

fn classify_score(score: Int) -> String {
    match score {
        90..=100 => "Excellent",
        70..=89  => "Good",
        50..=69  => "Average",
        0..=49   => "Poor",
        _        => "Invalid",
    }
}

fn main() -> Unit {
    // --- Test 1: Inclusive int range ---

    assert_eq(classify_int(0), "low",  "0 is low")
    assert_eq(classify_int(2), "low",  "2 is low (inclusive)")
    assert_eq(classify_int(3), "mid",  "3 is mid")
    assert_eq(classify_int(7), "mid",  "7 is mid (inclusive)")
    assert_eq(classify_int(8), "high", "8 is high")
    assert_eq(classify_int(12), "high","12 is high (inclusive)")
    assert_eq(classify_int(13), "very high", "13 is very high")
    print("Test 1 passed: inclusive int range patterns")

    // --- Test 2: Float range ---

    assert_eq(classify_float(1.0), "A", "1.0 = A")
    assert_eq(classify_float(0.9), "A", "0.9 = A (inclusive)")
    assert_eq(classify_float(0.85), "B", "0.85 = B")
    assert_eq(classify_float(0.72), "C", "0.72 = C")
    assert_eq(classify_float(0.5), "F", "0.5 = F")
    print("Test 2 passed: float range patterns")

    // --- Test 3: Score classification ---

    assert_eq(classify_score(95), "Excellent", "95 = Excellent")
    assert_eq(classify_score(75), "Good", "75 = Good")
    assert_eq(classify_score(60), "Average", "60 = Average")
    assert_eq(classify_score(30), "Poor", "30 = Poor")
    assert_eq(classify_score(101), "Invalid", "101 = Invalid")
    print("Test 3 passed: score classification ranges")

    // --- Test 4: Exclusive range (n..m) ---

    let x = 5
    let label = match x {
        0..5  => "0-4",
        5..10 => "5-9",
        _     => "10+",
    }
    assert_eq(label, "5-9", "exclusive range 5..10")

    let y = 4
    let label2 = match y {
        0..5  => "0-4",
        5..10 => "5-9",
        _     => "10+",
    }
    assert_eq(label2, "0-4", "exclusive range: 4 in 0..5")
    print("Test 4 passed: exclusive range patterns")

    // --- Test 5: Range patterns classify a list ---

    let numbers = [1, 3, 7, 10, 2, 8, 5, 12]
    let categories = list_map(numbers, |n| match n {
        1..=5  => "low",
        6..=12 => "high",
        _      => "other",
    })
    let lows  = list_filter(categories, |c| c == "low")
    let highs = list_filter(categories, |c| c == "high")
    assert_eq(list_len(lows), 4, "4 lows")
    assert_eq(list_len(highs), 4, "4 highs")
    print($"Test 5 passed: lows={list_len(lows)}, highs={list_len(highs)}")

    print("All range pattern tests passed!")
}
