// ============================================================
// Test: #[tool] annotation — tool registration and schema
// ============================================================
module Tests.ToolAnnotation

#[tool("Add two integers together")]
fn add(a: Int, b: Int) -> Int {
    a + b
}

#[tool("Greet someone by name")]
fn greet_tool(name: String, greeting: String = "Hello") -> String {
    "{greeting}, {name}!"
}

#[tool]
fn multiply(x: Int, y: Int) -> Int {
    x * y
}

fn main() -> Unit {
    // ── Tool registration ─────────────────────────────────────
    let tools = tool_list()
    assert(list_contains(tools, "add"),        "add registered as tool")
    assert(list_contains(tools, "greet_tool"), "greet_tool registered as tool")
    assert(list_contains(tools, "multiply"),   "multiply registered as tool")

    // ── Schema retrieval ──────────────────────────────────────
    let schema_opt = tool_schema("add")
    assert(option_is_some(schema_opt), "add has schema")

    let schema = option_unwrap(schema_opt)
    let name_val = json_get(schema, "name")
    assert_eq(option_unwrap(name_val), "add", "schema name")

    let desc_val = json_get(schema, "description")
    assert_eq(option_unwrap(desc_val), "Add two integers together", "schema description")

    let params = option_unwrap(json_get(schema, "parameters"))
    let props  = option_unwrap(json_get(params, "properties"))
    assert(option_is_some(json_get(props, "a")), "schema has param 'a'")
    assert(option_is_some(json_get(props, "b")), "schema has param 'b'")

    // ── Unknown tool returns None ─────────────────────────────
    let no_schema = tool_schema("no_such_tool")
    assert(option_is_none(no_schema), "unknown tool -> None")

    // ── The functions still work normally ─────────────────────
    assert_eq(add(3, 4), 7, "tool fn still callable")
    assert_eq(multiply(5, 6), 30, "multiply works")
    assert_eq(greet_tool("Alice"), "Hello, Alice!", "greet_tool with default")
    assert_eq(greet_tool("Bob", "Hi"), "Hi, Bob!", "greet_tool with arg")

    print("PASS: tool_annotation")
}
